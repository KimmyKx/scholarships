<%- contentFor('head') %>
    <title>User Profile</title>
<%- contentFor('body') %>
    <br>
    <div class="content bg-light rounded p-3 shadow mb-5 rounded" style="width: 100vw; max-width: 700px;">
        <form>
            <fieldset>
                <legend>Student's Informations</legend>
                <div class="mb-3">
                    <!-- Image preview element -->
                    <img id="profileImagePreview" src="/images/no_image.jpg" alt="Image Preview" class="img-fluid mt-3" style="width: 200px; height: 200px;">
                    <br>
                    <label for="profileFile" class="form-label">Choose a profile picture</label>
                    <input class="form-control" type="file" id="profileFile" accept="image/*">
                </div>

                <div class="mb-3">
                    <label for="disabledTextInput" class="form-label">Student Name</label>
                    <input type="text" id="disabledTextInput" class="form-control" placeholder="<%- user.name%>" disabled>
                </div>
                <div class="mb-3">
                    <label for="disabledTextInput" class="form-label">Student ID</label>
                    <input type="text" id="disabledTextInput" class="form-control" placeholder="<%- user.username.split('@')[0] %>" disabled>
                </div>
                <div class="mb-3">
                    <label for="disabledTextInput" class="form-label">ARC/UI No.</label>
                    <input type="text" id="disabledTextInput" class="form-control" placeholder="F800XXXXXX">
                </div>
                <div class="d-flex">
                    <div class="mb-3">
                        <label for="arcFileF" class="form-label">ARC Front</label>
                        <input class="form-control" type="file" id="arcFileF" accept="image/*">
                        <img id="arcFileFPreview" src="/images/arc_f.jpg" alt="Image Preview" class="img-fluid mt-3" style="width: 128px; height: 72px;">
                    </div>
                    <div class="mb-3">
                        <label for="arcFileB" class="form-label">ARC Back</label>
                        <input class="form-control" type="file" id="arcFileB" accept="image/*">
                        <img id="arcFileBPreview" src="/images/arc_b.jpg" alt="Image Preview" class="img-fluid mt-3" style="width: 128px; height: 72px;">
                    </div>
                </div>
                <div class="mb-3">
                    <label for="bankBookFile" class="form-label">Bank Book</label>
                    <input class="form-control" type="file" id="bankBookFile" accept="image/*">
                    <img id="bankBookPreview" src="/images/bank_book.jpg" alt="Image Preview" class="img-fluid mt-3" style="width: 384px; height: 216px;">
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </fieldset>
        </form>
    </div>
    <br><br>
<%- contentFor('footer') %>
    <script>
        const profileFile = document.getElementById('profileFile');
        const profileImagePreview = document.getElementById('profileImagePreview');

        profileFile.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    profileImagePreview.src = e.target.result;
                    profileImagePreview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                profileImagePreview.src = '#';
                profileImagePreview.style.display = 'none';
            }
        });
        const arcFileF = document.getElementById('arcFileF');
        const arcFileFPreview = document.getElementById('arcFileFPreview');

        arcFileF.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    arcFileFPreview.src = e.target.result;
                    arcFileFPreview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                arcFileFPreview.src = '#';
                arcFileFPreview.style.display = 'none';
            }
        });
        const arcFileB = document.getElementById('arcFileB');
        const arcFileBPreview = document.getElementById('arcFileBPreview');

        arcFileB.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    arcFileBPreview.src = e.target.result;
                    arcFileBPreview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                arcFileBPreview.src = '#';
                arcFileBPreview.style.display = 'none';
            }
        });
        
        const bankBookFile = document.getElementById('bankBookFile');
        const bankBookPreview = document.getElementById('bankBookPreview');

        bankBookFile.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    bankBookPreview.src = e.target.result;
                    bankBookPreview.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                bankBookPreview.src = '#';
                bankBookPreview.style.display = 'none';
            }
        });
    </script>